# Password to protect the site (leave empty for no protection)
SITE_PASSWORD=

# Sanity CMS – get these from sanity.io/manage after running `npx sanity init`
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production

# Sanity API token (read-only) – only needed if dataset is private
# SANITY_API_TOKEN=

# Google Places API – used server-side only, never sent to the client
# IMPORTANT: In Google Cloud Console the key must NOT have HTTP referrer restrictions —
# use IP restrictions or "None" so Next.js server-side requests are allowed.
GOOGLE_PLACES_API_KEY=your-key-here

# Google Place ID for the business
# Find it at: https://developers.google.com/maps/documentation/javascript/examples/places-placeid-finder
GOOGLE_PLACE_ID=your-place-id-here

# Google Analytics 4 – Measurement ID (public, loaded client-side).
# GA tag only fires after Consent Mode v2 grants analytics_storage.
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ─── Stripe (Plan 3 — /gutscheine) ────────────────────────────────────
# Test-Mode keys: pk_test_... / sk_test_... — get from dashboard.stripe.com
# Live-Mode swap: replace with pk_live_... / sk_live_... after Domenic verifies
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Webhook signing secret — generated by `stripe listen` for local dev,
# or copied from Stripe Dashboard → Developers → Webhooks → Endpoint signing secret for production
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs — populated by running scripts/setup-stripe-products.ts
# (creates 7 products idempotently, prints the env-var block to paste here)
STRIPE_PRICE_BLOCK_5_30=
STRIPE_PRICE_BLOCK_5_45=
STRIPE_PRICE_BLOCK_5_60=
STRIPE_PRICE_BLOCK_10_30=
STRIPE_PRICE_BLOCK_10_45=
STRIPE_PRICE_BLOCK_10_60=
STRIPE_PRICE_VOUCHER_CUSTOM=

# ─── Resend (transactional emails) ────────────────────────────────────
# Get from resend.com → API Keys
RESEND_API_KEY=re_...
# Dev: "onboarding@resend.dev" works without domain verification, restricted to verified addresses
# Live: "Heilmasseur Domenic Hacker <noreply@heilmasseur-domenic.at>" after domain verify in Resend
EMAIL_FROM="Heilmasseur Domenic Hacker <onboarding@resend.dev>"

# ─── App ──────────────────────────────────────────────────────────────
# Used in PDF voucher booking URL and Stripe return_url
NEXT_PUBLIC_APP_URL=http://localhost:3000
